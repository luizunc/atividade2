<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agendamento de Consulta</title>
  <meta name="description" content="Formulário de agendamento de consulta médica.">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

  <nav class="navbar navbar-dark bg-primary">
    <div class="container">
      <span class="navbar-brand fw-semibold">Agendamento de Consulta</span>
    </div>
  </nav>

  <div class="container my-4">
    <form action="/" method="POST" novalidate>

      <div class="card mb-4">
        <div class="card-header">
          <h2 class="h5 mb-0">Dados do Paciente</h2>
        </div>
        <div class="card-body">
          <div class="row g-3">

            <div class="col-md-6">
              <label for="nome" class="form-label">Nome <span class="text-danger">*</span></label>
              <input type="text" id="nome" name="nome"
                class="form-control {{#erros.nome}}is-invalid{{/erros.nome}}"
                value="{{dadosFormulario.nome}}" placeholder="Nome">
              {{#erros.nome}}<div class="invalid-feedback">{{erros.nome}}</div>{{/erros.nome}}
            </div>

            <div class="col-md-6">
              <label for="sobrenome" class="form-label">Sobrenome <span class="text-danger">*</span></label>
              <input type="text" id="sobrenome" name="sobrenome"
                class="form-control {{#erros.sobrenome}}is-invalid{{/erros.sobrenome}}"
                value="{{dadosFormulario.sobrenome}}" placeholder="Sobrenome">
              {{#erros.sobrenome}}<div class="invalid-feedback">{{erros.sobrenome}}</div>{{/erros.sobrenome}}
            </div>

            <div class="col-md-6">
              <label for="cpf" class="form-label">CPF <span class="text-danger">*</span></label>
              <input type="text" id="cpf" name="cpf"
                class="form-control {{#erros.cpf}}is-invalid{{/erros.cpf}}"
                value="{{dadosFormulario.cpf}}" placeholder="000.000.000-00" maxlength="14">
              {{#erros.cpf}}<div class="invalid-feedback">{{erros.cpf}}</div>{{/erros.cpf}}
            </div>

            <div class="col-md-6">
              <label for="dataNascimento" class="form-label">Data de Nascimento <span class="text-danger">*</span></label>
              <input type="date" id="dataNascimento" name="dataNascimento"
                class="form-control {{#erros.dataNascimento}}is-invalid{{/erros.dataNascimento}}"
                value="{{dadosFormulario.dataNascimento}}">
              {{#erros.dataNascimento}}<div class="invalid-feedback">{{erros.dataNascimento}}</div>{{/erros.dataNascimento}}
            </div>

            <div class="col-md-6">
              <label for="telefone" class="form-label">Telefone <span class="text-danger">*</span></label>
              <input type="text" id="telefone" name="telefone"
                class="form-control {{#erros.telefone}}is-invalid{{/erros.telefone}}"
                value="{{dadosFormulario.telefone}}" placeholder="(00) 00000-0000" maxlength="15">
              {{#erros.telefone}}<div class="invalid-feedback">{{erros.telefone}}</div>{{/erros.telefone}}
            </div>

            <div class="col-md-6">
              <label for="cep" class="form-label">CEP <span class="text-danger">*</span></label>
              <input type="text" id="cep" name="cep"
                class="form-control {{#erros.cep}}is-invalid{{/erros.cep}}"
                value="{{dadosFormulario.cep}}" placeholder="00000-000" maxlength="9">
              {{#erros.cep}}<div class="invalid-feedback">{{erros.cep}}</div>{{/erros.cep}}
            </div>

            <div class="col-12">
              <label for="endereco" class="form-label">Endereço <span class="text-danger">*</span></label>
              <input type="text" id="endereco" name="endereco"
                class="form-control {{#erros.endereco}}is-invalid{{/erros.endereco}}"
                value="{{dadosFormulario.endereco}}" placeholder="Rua, número, bairro, cidade - UF">
              {{#erros.endereco}}<div class="invalid-feedback">{{erros.endereco}}</div>{{/erros.endereco}}
            </div>

          </div>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-header">
          <h2 class="h5 mb-0">Dados da Consulta</h2>
        </div>
        <div class="card-body">
          <div class="row g-3">

            <div class="col-md-6">
              <label for="clinica" class="form-label">Clínica <span class="text-danger">*</span></label>
              <select id="clinica" name="clinica"
                class="form-select {{#erros.clinica}}is-invalid{{/erros.clinica}}">
                <option value="">Selecione</option>
                <option value="Clínica Central">Clínica Central</option>
                <option value="Clínica Norte">Clínica Norte</option>
                <option value="Clínica Sul">Clínica Sul</option>
                <option value="Clínica Leste">Clínica Leste</option>
                <option value="Clínica Oeste">Clínica Oeste</option>
              </select>
              {{#erros.clinica}}<div class="invalid-feedback">{{erros.clinica}}</div>{{/erros.clinica}}
            </div>

            <div class="col-md-6">
              <label for="especialidade" class="form-label">Especialidade <span class="text-danger">*</span></label>
              <select id="especialidade" name="especialidade"
                class="form-select {{#erros.especialidade}}is-invalid{{/erros.especialidade}}">
                <option value="">Selecione</option>
                <option value="Cardiologia">Cardiologia</option>
                <option value="Dermatologia">Dermatologia</option>
                <option value="Endocrinologia">Endocrinologia</option>
                <option value="Ginecologia">Ginecologia</option>
                <option value="Neurologia">Neurologia</option>
                <option value="Oftalmologia">Oftalmologia</option>
                <option value="Ortopedia">Ortopedia</option>
                <option value="Pediatria">Pediatria</option>
                <option value="Clínica Geral">Clínica Geral</option>
              </select>
              {{#erros.especialidade}}<div class="invalid-feedback">{{erros.especialidade}}</div>{{/erros.especialidade}}
            </div>

            <div class="col-md-6">
              <label for="dataAgendamento" class="form-label">Data do Agendamento <span class="text-danger">*</span></label>
              <input type="date" id="dataAgendamento" name="dataAgendamento"
                class="form-control {{#erros.dataAgendamento}}is-invalid{{/erros.dataAgendamento}}"
                value="{{dadosFormulario.dataAgendamento}}">
              {{#erros.dataAgendamento}}<div class="invalid-feedback">{{erros.dataAgendamento}}</div>{{/erros.dataAgendamento}}
            </div>

            <div class="col-md-6">
              <label for="horaAgendamento" class="form-label">Hora do Agendamento <span class="text-danger">*</span></label>
              <input type="time" id="horaAgendamento" name="horaAgendamento"
                class="form-control {{#erros.horaAgendamento}}is-invalid{{/erros.horaAgendamento}}"
                value="{{dadosFormulario.horaAgendamento}}">
              {{#erros.horaAgendamento}}<div class="invalid-feedback">{{erros.horaAgendamento}}</div>{{/erros.horaAgendamento}}
            </div>

            <div class="col-12">
              <label for="observacao" class="form-label">Observação</label>
              <textarea id="observacao" name="observacao" class="form-control" rows="4"
                placeholder="Informações adicionais para o médico (opcional)">{{dadosFormulario.observacao}}</textarea>
            </div>

          </div>
        </div>
      </div>

      <div class="text-end">
        <p class="text-muted small mb-2"><span class="text-danger">*</span> Campos obrigatórios</p>
        <button type="submit" id="btnEnviar" class="btn btn-primary px-4">Enviar</button>
      </div>

    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
