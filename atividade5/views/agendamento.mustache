<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agendamento Confirmado</title>
  <meta name="description" content="Dados do agendamento de consulta realizado.">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

  <nav class="navbar navbar-dark bg-primary">
    <div class="container">
      <span class="navbar-brand fw-semibold">Agendamento de Consulta</span>
    </div>
  </nav>

  <div class="container my-4">

    <div class="alert alert-success" role="alert">
      Agendamento realizado com sucesso!
    </div>

    <div class="card mb-4">
      <div class="card-header">
        <h2 class="h5 mb-0">Dados do Paciente</h2>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Nome Completo</dt>
          <dd class="col-sm-8">{{agendamento.nome}} {{agendamento.sobrenome}}</dd>

          <dt class="col-sm-4">CPF</dt>
          <dd class="col-sm-8">{{agendamento.cpf}}</dd>

          <dt class="col-sm-4">Data de Nascimento</dt>
          <dd class="col-sm-8">{{agendamento.dataNascimento}}</dd>

          <dt class="col-sm-4">Telefone</dt>
          <dd class="col-sm-8">{{agendamento.telefone}}</dd>

          <dt class="col-sm-4">CEP</dt>
          <dd class="col-sm-8">{{agendamento.cep}}</dd>

          <dt class="col-sm-4">Endereço</dt>
          <dd class="col-sm-8">{{agendamento.endereco}}</dd>
        </dl>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">
        <h2 class="h5 mb-0">Dados da Consulta</h2>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Clínica</dt>
          <dd class="col-sm-8">{{agendamento.clinica}}</dd>

          <dt class="col-sm-4">Especialidade</dt>
          <dd class="col-sm-8">{{agendamento.especialidade}}</dd>

          <dt class="col-sm-4">Data do Agendamento</dt>
          <dd class="col-sm-8">{{agendamento.dataAgendamento}}</dd>

          <dt class="col-sm-4">Hora do Agendamento</dt>
          <dd class="col-sm-8">{{agendamento.horaAgendamento}}</dd>

          {{#agendamento.observacao}}
          <dt class="col-sm-4">Observação</dt>
          <dd class="col-sm-8">{{agendamento.observacao}}</dd>
          {{/agendamento.observacao}}
        </dl>
      </div>
    </div>

    <div class="text-end">
      <a href="/" id="btnNovoAgendamento" class="btn btn-primary">Novo Agendamento</a>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
